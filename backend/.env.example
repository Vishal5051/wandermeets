# WanderMates Backend Environment Variables

# Server Port
PORT=5000
NODE_ENV=development

# Database Connection (Standard Parameters)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wandermeets
DB_USER=root
DB_PASSWORD=

# Database Connection (Alternative URI - Preferred for Railway)
# DATABASE_URL=mysql://root:password@host:port/database
# MYSQL_URL=mysql://root:password@host:port/database

# JWT Settings
JWT_SECRET=your_jwt_secret_key_here

# CORS Configuration (Restricts API access in production)
FRONTEND_URL=http://localhost:3000

# File Upload Settings
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880 # 5MB in bytes

# Email Notifications (Gmail/SMTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=WanderMates <your_email@gmail.com>

# Twilio Configuration (Optional - for SMS & SOS Services)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_VERIFY_SERVICE_ID=VAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
